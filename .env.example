# Database
DATABASE_URL=postgresql://user:password@host:port/database

# Admin Authentication
ADMIN_PASSWORD=your-secure-admin-password
ADMIN_SECRET=random-32-character-secret-for-signing-cookies
ADMIN_USERNAME=admin

# Stripe Payment (Optional - for payment functionality)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# AWS SES SMTP Configuration (Optional - for email functionality)
# Leave these blank if you don't want to send emails
# SES_SMTP_HOST=email-smtp.us-west-2.amazonaws.com
# SES_SMTP_PORT=465
# SES_SMTP_USER=your-ses-smtp-username
# SES_SMTP_PASS=your-ses-smtp-password
# SES_FROM_EMAIL=hello@goranhodzic.art

# Email Security (Required only if using email)
# UNSUBSCRIBE_SECRET=random-32-character-secret-for-unsubscribe-tokens

# Application
NEXT_PUBLIC_SITE_URL=https://goranhodzic.art

# Cron Job Security (Optional - for scheduled sends)
# CRON_SECRET=random-32-character-secret-for-cron-auth